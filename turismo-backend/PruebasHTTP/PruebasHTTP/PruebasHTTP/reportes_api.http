Content-Type: {{contentType}}
Authorization: Bearer {{authToken}}

{
    "facilidades_discapacidad": true,
    "formato": "pdf",
    "incluir_estadisticas": true,
    "incluir_graficos": false,
    "orientacion": "portrait"
}

