Content-Type: {{contentType}}
Authorization: Bearer {{authToken}}

{
    "tipo_servicio": "restaurant",
    "precio_min": 25,
    "precio_max": 100,
    "formato": "pdf",
    "incluir_estadisticas": true,
    "incluir_graficos": true,
